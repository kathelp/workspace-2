# 1Password secret references for just-in-time injection.
# Copy to .env.1password and replace example vault/item names.
# These are references, not the secret values themselves.

OPENAI_API_KEY=op://Private/OpenClaw Workspace/openai_api_key
ANTHROPIC_API_KEY=op://Private/OpenClaw Workspace/anthropic_api_key
GITHUB_TOKEN=op://Private/OpenClaw Workspace/github_token
TODOIST_API_TOKEN=op://Private/OpenClaw Workspace/todoist_api_token
NOTION_TOKEN=op://Private/OpenClaw Workspace/notion_token
