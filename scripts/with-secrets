#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${OP_ENV_FILE:-$ROOT/.env.1password}"

if ! command -v op >/dev/null 2>&1; then
  echo "1Password CLI (op) is not installed or not on PATH." >&2
  exit 1
fi

if [ ! -f "$ENV_FILE" ]; then
  echo "Missing env reference file: $ENV_FILE" >&2
  echo "Create it from .env.1password.example" >&2
  exit 1
fi

if [ "$#" -eq 0 ]; then
  echo "Usage: scripts/with-secrets <command> [args...]" >&2
  exit 1
fi

exec op run --env-file="$ENV_FILE" -- "$@"
